      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const jwt = require('jsonwebtoken');\nconst body = $input.first().json.body;\nconst authHeader = $input.first().json.headers?.authorization;\nif (!authHeader || !authHeader.startsWith('Bearer ')) {\n  throw new Error('Nicht autorisiert');\n}\nconst token = authHeader.split(' ')[1];\nlet decoded;\ntry {\n  decoded = jwt.verify(token, 'BOXENFUNK_SECRET_2026');\n} catch(e) {\n  throw new Error('Token ungültig oder abgelaufen');\n}\nif (!body.race_id || !body.tipp_sieger) {\n  throw new Error('race_id und tipp_sieger erforderlich');\n}\nreturn [{ json: { user_id: decoded.user_id, username: decoded.username, race_id: body.race_id, tipp_sieger: body.tipp_sieger, tipp_p2: body.tipp_p2 || '', tipp_p3: body.tipp_p3 || '', tipp_fastest_lap: body.tipp_fastest_lap || '', tipp_safety_car: body.tipp_safety_car || false } }];"
      },
      "name": "Verify JWT",
      "type": "n8n-nodes-base.code",
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/databases/9918e5afd4e448ed85f6fdefeb659107/query",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 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" },
            { "name": "Notion-Version", "value": "2022-06-28" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"filter\": { \"property\": \"Name\", \"title\": { \"equals\": \"{{ $json.race_id }}\" } } }"
      },
      "name": "Check Race Open",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const race = $input.first().json.results?.[0];\nif (!race) throw new Error('Rennen nicht gefunden');\nif (race.properties.tipps_gesperrt.checkbox) throw new Error('Tipps sind gesperrt - Rennen hat bereits begonnen');\nconst tip = $('Verify JWT').first().json;\nreturn [{ json: { ...tip, race_notion_id: race.id } }];"
      },
      "name": "Check Not Locked",
      "type": "n8n-nodes-base.code",
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.notion.com/v1/pages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer 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" },
            { "name": "Notion-Version", "value": "2022-06-28" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"parent\": { \"database_id\": \"cd0e5d12be1048ed9e5fbf514f7e2df7\" },\n  \"properties\": {\n    \"Name\": { \"title\": [{ \"text\": { \"content\": \"TIP-{{ $json.user_id.slice(0,8) }}-{{ $json.race_id }}\" } }] },\n    \"user_id\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.user_id }}\" } }] },\n    \"race_id\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.race_notion_id }}\" } }] },\n    \"tipp_sieger\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.tipp_sieger }}\" } }] },\n    \"tipp_p2\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.tipp_p2 }}\" } }] },\n    \"tipp_p3\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.tipp_p3 }}\" } }] },\n    \"tipp_fastest_lap\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $json.tipp_fastest_lap }}\" } }] },\n    \"tipp_safety_car\": { \"checkbox\": {{ $json.tipp_safety_car }} },\n    \"punkte_sieger\": { \"number\": 0 },\n    \"punkte_podium\": { \"number\": 0 },\n    \"punkte_fastest\": { \"number\": 0 },\n    \"punkte_sc\": { \"number\": 0 },\n    \"erstellt_am\": { \"date\": { \"start\": \"{{ new Date().toISOString() }}\" } }\n  }\n}"
      },
      "name": "Save Tip",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: true, message: 'Tipp erfolgreich gespeichert', tip_id: $input.first().json.id } }];"
      },
      "name": "Return Success",
      "type": "n8n-nodes-base.code",
      "position": [1340, 300]
    }
  ],
